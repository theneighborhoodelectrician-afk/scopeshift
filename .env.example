DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scopeshift?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# Optional: `npm run db:seed` creates a demo org, team, and owner user. Override in production.
# SEED_ORG_NAME="Local Demo Company"
# SEED_ORG_SLUG="local"
# SEED_TEAM_NAME="Field Team A"
# SEED_ADMIN_EMAIL="admin@scopeshift.local"
# SEED_ADMIN_PASSWORD="scopeshift"
